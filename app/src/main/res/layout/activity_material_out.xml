<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#E3E7EC"
        android:orientation="vertical">

        <TextView
            android:id="@+id/txtManuName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="@font/bungee"
            android:text="MALZEME ÇIKIŞ"
            android:textColor="#20262B"
            android:textSize="26sp"
            android:textStyle="bold"
            android:gravity="center" />

        <EditText
            android:id="@+id/editTextRFID"
            android:layout_width="match_parent"
            android:layout_height="45dp"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="8dp"
            android:layout_marginBottom="6dp"
            android:background="@drawable/text_bg"
            android:ems="10"
            android:fontFamily="@font/sans"
            android:hint="Rfid okutunuz..."
            android:inputType="textPersonName"
            android:paddingStart="8dp"
            android:textColor="#FFFFFF"
            android:textColorHint="@android:color/white"
            android:textSize="18sp" />

        <LinearLayout
            xmlns:android="http://schemas.android.com/apk/res/android"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="8dp"
            android:layout_marginBottom="12dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:weightSum="4">

            <com.example.rndlaboratorystock.Classes.AnimatedButton
                android:id="@+id/btnMaterialMenuBack"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_weight="1"
                android:background="@drawable/button_bg"
                android:fontFamily="@font/sans"
                android:text="GERİ"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TableLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginHorizontal="4dp"
                android:background="#E3E7EC"
                android:stretchColumns="*">
                <TableRow android:background="#20262B" android:padding="2dp">
                    <TextView
                        android:fontFamily="@font/sans"
                        android:gravity="center"
                        android:text="RFID ADET"
                        android:textColor="#FFFFFF"
                        android:textSize="9sp"
                        android:textStyle="bold" />
                </TableRow>
                <TableRow android:background="#FFFFFF" android:padding="4dp">
                    <TextView
                        android:id="@+id/txtEpcCount"
                        android:gravity="center"
                        android:text="0"
                        android:textSize="16sp"
                        android:textStyle="bold" />
                </TableRow>
            </TableLayout>

            <com.example.rndlaboratorystock.Classes.AnimatedButton
                android:id="@+id/btnReset"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_weight="1"
                android:layout_marginEnd="2dp"
                android:background="@drawable/button_bg"
                android:fontFamily="@font/sans"
                android:text="RESET"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold" />

            <com.example.rndlaboratorystock.Classes.AnimatedButton
                android:id="@+id/btnDelete"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_weight="1"
                android:background="@drawable/button_bg"
                android:fontFamily="@font/sans"
                android:text="ONAYLA"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingLeft="8dp"
            android:paddingRight="8dp">

            <TableLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#E3E7EC"
                android:stretchColumns="*">

                <TableRow
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="#20262B"
                    android:padding="4dp">

                    <TextView
                        android:fontFamily="@font/sans"
                        android:gravity="center"
                        android:padding="8dp"
                        android:text="#"
                        android:textColor="#FFFFFF" />

                    <TextView
                        android:fontFamily="@font/sans"
                        android:gravity="center"
                        android:padding="8dp"
                        android:text="EPC"
                        android:textColor="#FFFFFF" />
                </TableRow>
            </TableLayout>

            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:fillViewport="true">

                <TableLayout
                    android:id="@+id/tableData2"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:stretchColumns="*" />
            </ScrollView>
        </LinearLayout>

    </LinearLayout>

    <FrameLayout
        android:id="@+id/failOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#88000000"
        android:visibility="gone">

        <TextView
            android:id="@+id/txtFail"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:background="@drawable/fail_background"
            android:padding="16dp"
            android:text=""
            android:textAlignment="center"
            android:textColor="#FFFFFF"
            android:textSize="24sp"
            android:textStyle="bold" />
    </FrameLayout>

    <FrameLayout
        android:id="@+id/successOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#88000000"
        android:visibility="gone">

        <TextView
            android:id="@+id/txtSuccess"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="24sp"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:background="@drawable/success_background"
            android:padding="16dp"
            android:layout_gravity="center" />
    </FrameLayout>
    <!-- Konfeti Animasyonu -->
    <com.airbnb.lottie.LottieAnimationView
        android:id="@+id/confettiView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:lottie_rawRes="@raw/fireworks_animation"
        app:lottie_autoPlay="false"
        app:lottie_loop="false"
        android:visibility="gone"
        android:clickable="false"
        android:focusable="false" />

</FrameLayout>