<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <!-- ScrollView içeriği -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#E3E7EC"
            android:orientation="vertical"
            android:padding="12dp">

            <TextView
                android:id="@+id/txtLabName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="@font/bungee"
                android:text="STOK GÜNCELLE"
                android:textColor="#20262B"
                android:textSize="26sp"
                android:textStyle="bold"
                android:gravity="center" />

            <TableLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:stretchColumns="*"
                android:background="#E3E7EC"
                android:padding="8dp">

                <!-- Header Satırı -->
                <TableRow
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="#20262B"
                    android:padding="4dp">

                    <TextView
                        android:text="EPC"
                        android:textColor="#FFFFFF"
                        android:gravity="center"
                        android:fontFamily="@font/sans"
                        android:padding="8dp"/>

                </TableRow>

                <!-- Veri Satırı -->
                <TableRow
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="#FFFFFF"
                    android:padding="4dp">

                    <EditText
                        android:id="@+id/editTextRFID"
                        android:layout_width="match_parent"
                        android:layout_height="45dp"
                        android:layout_marginStart="8dp"
                        android:layout_marginEnd="8dp"
                        android:layout_marginBottom="8dp"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/text_bg"
                        android:ems="10"
                        android:hint="RFID okutunuz..."
                        android:textColorHint="@android:color/white"
                        android:fontFamily="@font/sans"
                        android:inputType="textPersonName"
                        android:paddingStart="8dp"
                        android:textColor="#FFFFFF"
                        android:textSize="18sp" />

                </TableRow>

            </TableLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#E3E7EC"
                android:orientation="horizontal"
                android:weightSum="2" >

                <TableLayout
                    android:layout_width="180dp"
                    android:layout_height="wrap_content"
                    android:stretchColumns="*"
                    android:background="#E3E7EC"
                    android:layout_weight="1"
                    android:padding="8dp">

                    <!-- Header Satırı -->
                    <TableRow
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="#20262B"
                        android:padding="4dp">

                        <TextView
                            android:text="MALZEME ADI"
                            android:fontFamily="@font/sans"
                            android:textColor="#FFFFFF"
                            android:gravity="center"
                            android:padding="8dp"/>

                    </TableRow>

                    <!-- Veri Satırı -->
                    <TableRow
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="#FFFFFF"
                        android:padding="4dp">

                        <TextView
                            android:id="@+id/txtMaterialName"
                            android:text="-"
                            android:fontFamily="@font/sans"
                            android:gravity="center"
                            android:padding="8dp"/>

                    </TableRow>

                </TableLayout>

                <TableLayout
                    android:layout_width="180dp"
                    android:layout_height="wrap_content"
                    android:stretchColumns="*"
                    android:background="#E3E7EC"
                    android:layout_weight="1"
                    android:padding="8dp">

                    <!-- Header Satırı -->
                    <TableRow
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="#20262B"
                        android:padding="4dp">

                        <TextView
                            android:text="AMBAR KODU"
                            android:fontFamily="@font/sans"
                            android:textColor="#FFFFFF"
                            android:gravity="center"
                            android:padding="8dp"/>

                    </TableRow>

                    <!-- Veri Satırı -->
                    <TableRow
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="#FFFFFF"
                        android:padding="4dp">

                        <TextView
                            android:id="@+id/txtWarehouseCode"
                            android:text="-"
                            android:fontFamily="@font/sans"
                            android:gravity="center"
                            android:padding="8dp"/>

                    </TableRow>

                </TableLayout>

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#E3E7EC"
                android:orientation="horizontal"
                android:weightSum="2" >

                <TableLayout
                    android:layout_width="180dp"
                    android:layout_height="wrap_content"
                    android:stretchColumns="*"
                    android:background="#E3E7EC"
                    android:layout_weight="1"
                    android:padding="8dp">

                    <!-- Header Satırı -->
                    <TableRow
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="#20262B"
                        android:padding="4dp">

                        <TextView
                            android:text="STOK"
                            android:fontFamily="@font/sans"
                            android:textColor="#FFFFFF"
                            android:gravity="center"
                            android:padding="8dp"/>

                    </TableRow>

                    <!-- Veri Satırı -->
                    <TableRow
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="#FFFFFF"
                        android:padding="4dp">

                        <TextView
                            android:id="@+id/txtStock"
                            android:text="-"
                            android:fontFamily="@font/sans"
                            android:gravity="center"
                            android:padding="8dp"/>

                    </TableRow>

                </TableLayout>

                <TableLayout
                    android:layout_width="180dp"
                    android:layout_height="wrap_content"
                    android:stretchColumns="*"
                    android:background="#E3E7EC"
                    android:layout_weight="1"
                    android:padding="8dp">

                    <!-- Header Satırı -->
                    <TableRow
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="#20262B"
                        android:padding="4dp">

                        <TextView
                            android:text="KRİTİK STOK"
                            android:fontFamily="@font/sans"
                            android:textColor="#FFFFFF"
                            android:gravity="center"
                            android:padding="8dp"/>

                    </TableRow>

                    <!-- Veri Satırı -->
                    <TableRow
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="#FFFFFF"
                        android:padding="4dp">

                        <TextView
                            android:id="@+id/txtCriticalStock"
                            android:text="-"
                            android:fontFamily="@font/sans"
                            android:gravity="center"
                            android:padding="8dp"/>

                    </TableRow>

                </TableLayout>

            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:layout_marginEnd="10dp"
                android:layout_marginBottom="6dp"
                android:fontFamily="@font/sans"
                android:gravity="start"
                android:text="YENİ MİKTARI GİRİNİZ"
                android:textColor="#20262B"
                android:textSize="12sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/editTextNewQuantity"
                android:layout_width="match_parent"
                android:layout_height="45dp"
                android:layout_marginStart="8dp"
                android:layout_marginEnd="8dp"
                android:layout_marginBottom="6dp"
                android:background="@drawable/text_bg"
                android:ems="10"
                android:fontFamily="@font/sans"
                android:hint="Yeni miktar..."
                android:inputType="number"
                android:paddingStart="8dp"
                android:textColor="#FFFFFF"
                android:textColorHint="@android:color/white"
                android:textSize="18sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="0dp"
                android:layout_marginEnd="0dp"
                android:layout_marginBottom="0dp"
                android:gravity="center">

                <com.example.rndlaboratorystock.Classes.AnimatedButton
                    android:id="@+id/btnUpdate"
                    android:layout_width="120dp"
                    android:layout_height="50dp"
                    android:background="@drawable/button_bg"
                    android:fontFamily="@font/sans"
                    android:text="GÜNCELLE"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <FrameLayout
        android:id="@+id/failOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#88000000"
        android:visibility="gone">

        <TextView
            android:id="@+id/txtFail"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:background="@drawable/fail_background"
            android:padding="16dp"
            android:text=""
            android:textAlignment="center"
            android:textColor="#FFFFFF"
            android:textSize="24sp"
            android:textStyle="bold" />
    </FrameLayout>

    <FrameLayout
        android:id="@+id/successOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#88000000"
        android:visibility="gone">

        <TextView
            android:id="@+id/txtSuccess"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="24sp"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:background="@drawable/success_background"
            android:padding="16dp"
            android:layout_gravity="center" />
    </FrameLayout>
    <!-- Konfeti Animasyonu -->
    <com.airbnb.lottie.LottieAnimationView
        android:id="@+id/confettiView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:lottie_rawRes="@raw/fireworks_animation"
        app:lottie_autoPlay="false"
        app:lottie_loop="false"
        android:visibility="gone"
        android:clickable="false"
        android:focusable="false" />

</FrameLayout>
